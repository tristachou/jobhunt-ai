# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Choose: gemini (default) | ollama
LLM_PROVIDER=gemini

# ─── Gemini (used when LLM_PROVIDER=gemini) ───────────────────────────────────
# Get a free key at https://aistudio.google.com/
GEMINI_API_KEY=your_key_here

# Optional: override model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# ─── Ollama (used when LLM_PROVIDER=ollama) ───────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3:27b

# Optional: timeout in ms for Ollama requests (default: 120000 = 2 min)
# LLM_TIMEOUT_MS=120000

# ─── Other ────────────────────────────────────────────────────────────────────
# Optional: directory to save exported PDFs (v2 streams directly, rarely needed)
# OUTPUT_DIR=../output
